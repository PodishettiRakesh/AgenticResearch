# AgenticResearch Configuration Example
# Copy this file to .env and update with your values

# ===========================================
# LLM PROVIDER CONFIGURATION
# ===========================================

# Method 1: Simple provider selection (legacy)
# LLM_PROVIDER=gemini
# LLM_PROVIDER=ollama

# Method 2: Individual provider controls (NEW!)
# Enable/disable individual providers
GEMINI_ENABLED=true
OLLAMA_ENABLED=false

# Provider-specific settings
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

OLLAMA_MODEL=llama3:8b
OLLAMA_BASE_URL=http://localhost:11434

# ===========================================
# TASK CONFIGURATION
# ===========================================

MAX_CHUNKS_PER_TASK=6
MAX_TEXT_LENGTH=4000
TEMPERATURE=0.3
MAX_OUTPUT_TOKENS=2048

# ===========================================
# PROCESSING CONFIGURATION
# ===========================================

CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ===========================================
# SCRAPING CONFIGURATION
# ===========================================

REQUEST_TIMEOUT=30
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ===========================================
# REPORT CONFIGURATION
# ===========================================

OUTPUT_DIR=reports
REPORT_FORMAT=markdown

# ===========================================
# LOGGING CONFIGURATION
# ===========================================

LOG_LEVEL=INFO
LOG_FILE=agentic_research.log

# ===========================================
# USAGE EXAMPLES
# ===========================================

# Example 1: Use Gemini (cloud)
# GEMINI_ENABLED=true
# OLLAMA_ENABLED=false
# GEMINI_API_KEY=your_key_here

# Example 2: Use Ollama (local)
# GEMINI_ENABLED=false
# OLLAMA_ENABLED=true
# No API key needed!

# Example 3: Both enabled (auto-selection)
# GEMINI_ENABLED=true
# OLLAMA_ENABLED=true
# System will prefer Ollama if available, fallback to Gemini

# Example 4: Override at runtime
# python main.py --url "https://arxiv.org/html/2603.25702v1"
# LLM_PROVIDER=ollama streamlit run app.py
