# AgenticResearch Configuration Example
# Copy this file to .env and update with your values

# ===========================================
# LLM PROVIDER CONFIGURATION
# ===========================================

# Individual provider controls (NEW!)
GEMINI_ENABLED=false
OLLAMA_ENABLED=true

# Gemini configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Ollama configuration
OLLAMA_MODEL=llama3:8b
OLLAMA_BASE_URL=http://localhost:11435

# ===========================================
# CREWAI CONFIGURATION
# ===========================================

# Disable CrewAI telemetry to avoid connection issues
CREWAI_TELEMETRY_ENABLED=false

# ===========================================
# TASK CONFIGURATION
# ===========================================

MAX_CHUNKS_PER_TASK=6
MAX_TEXT_LENGTH=4000
TEMPERATURE=0.3
MAX_OUTPUT_TOKENS=2048

# ===========================================
# PROCESSING CONFIGURATION
# ===========================================

CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ===========================================
# SCRAPING CONFIGURATION
# ===========================================

REQUEST_TIMEOUT=30
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ===========================================
# REPORT CONFIGURATION
# ===========================================

OUTPUT_DIR=reports
REPORT_FORMAT=markdown

# ===========================================
# LOGGING CONFIGURATION
# ===========================================

LOG_LEVEL=INFO
LOG_FILE=agentic_research.log
LLM_PROVIDER=ollama

# ===========================================
# USAGE EXAMPLES
# ===========================================

# Example 1: Use Gemini (cloud)
# GEMINI_ENABLED=true
# OLLAMA_ENABLED=false
# GEMINI_API_KEY=your_key_here

# Example 2: Use Ollama (local)
# GEMINI_ENABLED=false
# OLLAMA_ENABLED=true
# No API key needed!

# Example 3: Both enabled (auto-selection)
# GEMINI_ENABLED=true
# OLLAMA_ENABLED=true
# System will auto-select based on availability

# ===========================================
# ADDITIONAL NOTES
# ===========================================

# Port Configuration:
# - Default Ollama port: 11434
# - Alternative port (if conflicts): 11435
# - Update OLLAMA_BASE_URL accordingly

# Model Selection:
# - Gemini: gemini-2.0-flash (cloud-based)
# - Ollama: llama3:8b (local-based)
# - System uses provider enabled in .env

# Report Organization:
# - All reports saved to: reports/ folder
# - Unique filenames with timestamps
# - Format: judgement_report_PAPERID_YYYYMMDD_HHMMSS.md

# Troubleshooting:
# - If port conflicts: change OLLAMA_BASE_URL
# - If Ollama slow: try smaller model (llama3:7b)
# - If telemetry errors: CREWAI_TELEMETRY_ENABLED=false
# System will prefer Ollama if available, fallback to Gemini

# Example 4: Override at runtime
# python main.py --url "https://arxiv.org/html/2603.25702v1"
# LLM_PROVIDER=ollama streamlit run app.py
